# ============================================================
# Digital CMO AI — Environment Variables
# Copy to .env and fill in your values
# DO NOT commit .env to version control
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://cmo:localdevpassword@postgres:5432/digitalcmo
POSTGRES_USER=cmo
POSTGRES_PASSWORD=localdevpassword
POSTGRES_DB=digitalcmo

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth ─────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
# SESSION_SECRET: separate secret for cookie/session signing (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-in-production-session-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# BCRYPT_ROUNDS: bcrypt cost factor (min 12 recommended, higher = slower hashing)
BCRYPT_ROUNDS=12

# ── App URLs ─────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# ── LLM Keys ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@digital-cmo.ai
SMTP_USE_TLS=true

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ── CORS & Security ──────────────────────────────────────────
# CORS_ORIGINS_CSV: comma-separated allowed origins (never use * in production)
CORS_ORIGINS_CSV=http://localhost:3000,http://localhost:80
# ALLOWED_ORIGINS: alias accepted by some middleware layers
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80
# MAX_UPLOAD_SIZE_MB: maximum allowed file upload size in megabytes
MAX_UPLOAD_SIZE_MB=10

# ── Dev flags ────────────────────────────────────────────────
DEBUG=true
