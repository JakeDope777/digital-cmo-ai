# Digital CMO AI - Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME="Digital CMO AI"
DEBUG=true

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///./data/digital_cmo.db
# DATABASE_URL=postgresql://user:password@localhost:5432/digital_cmo

# JWT Secret (CHANGE THIS in production!)
SECRET_KEY=your-secret-key-change-me-in-production

# LLM Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
# OPENAI_BASE_URL=  # Override for custom endpoints

# Memory
MEMORY_BASE_PATH=./memory

# HubSpot CRM
HUBSPOT_API_KEY=

# SendGrid Email
SENDGRID_API_KEY=

# Google Ads
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Google Analytics
GOOGLE_ANALYTICS_PROPERTY_ID=

# Meta Ads
META_ADS_ACCESS_TOKEN=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
