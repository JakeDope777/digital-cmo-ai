# ============================================================
# Digital CMO AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values you need.
# Any connector whose credentials are left blank will
# automatically fall back to demo/mock mode.
# ============================================================

# ── Application ────────────────────────────────────────────
APP_NAME="Digital CMO AI"
APP_VERSION=0.2.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/digital_cmo.db
# DATABASE_URL=postgresql://user:password@localhost:5432/digital_cmo

# ── JWT / Auth ─────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM Configuration ─────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
# OPENAI_BASE_URL=  # Override for custom endpoints

# ── Vector Database ────────────────────────────────────────
VECTOR_DB_PATH=./data/vector_store
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIMENSION=1536

# ── Memory ─────────────────────────────────────────────────
MEMORY_BASE_PATH=./memory

# ============================================================
# INTEGRATIONS & CONNECTORS (20 services)
# ============================================================
# Leave blank → connector runs in demo/mock mode.
# Fill in → connector uses the real API.
# ============================================================

# ── Advertising Platforms ──────────────────────────────────

# Google Ads (OAuth2)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# Meta / Facebook Ads (Access Token)
META_ADS_ACCESS_TOKEN=
META_ADS_APP_ID=
META_ADS_APP_SECRET=

# TikTok Ads (Access Token)
TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_ADVERTISER_ID=

# ── Social Media Platforms ─────────────────────────────────

# LinkedIn (OAuth2)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitter / X (Bearer Token)
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# Facebook Pages (Page Access Token)
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── Email Marketing ────────────────────────────────────────

# SendGrid (API Key)
SENDGRID_API_KEY=

# Mailchimp (API Key — includes dc prefix, e.g. abc123-us21)
MAILCHIMP_API_KEY=

# ── CRM Systems ───────────────────────────────────────────

# HubSpot (API Key or OAuth2 Access Token)
HUBSPOT_API_KEY=
HUBSPOT_ACCESS_TOKEN=

# Salesforce (OAuth2)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_INSTANCE_URL=

# Zoho CRM (OAuth2)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ── Analytics & Data ───────────────────────────────────────

# Google Analytics 4 (Property ID + Service Account JSON path)
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_ANALYTICS_CREDENTIALS_JSON=

# Mixpanel (API Secret)
MIXPANEL_API_SECRET=
MIXPANEL_PROJECT_ID=

# ── E-commerce & Payments ──────────────────────────────────

# Shopify (Admin API)
SHOPIFY_SHOP_NAME=
SHOPIFY_ACCESS_TOKEN=

# Stripe (Secret Key)
STRIPE_SECRET_KEY=

# ── Marketing Automation ───────────────────────────────────

# ActiveCampaign (API Key + Account URL)
ACTIVECAMPAIGN_API_KEY=
ACTIVECAMPAIGN_ACCOUNT_URL=

# Klaviyo (API Key)
KLAVIYO_API_KEY=

# ── SEO Tools ──────────────────────────────────────────────

# SEMrush (API Key)
SEMRUSH_API_KEY=

# ── Communication / Messaging ──────────────────────────────

# Slack (Bot Token)
SLACK_BOT_TOKEN=

# Twilio (Account SID + Auth Token)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Token Accounting ───────────────────────────────────────
FREE_TIER_MONTHLY_TOKENS=10000
PRO_TIER_MONTHLY_TOKENS=100000
ENTERPRISE_TIER_MONTHLY_TOKENS=1000000

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
