# ============================================================
# Digital CMO AI — Production Environment Variables
# ============================================================
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to version control.
#
# Required vars are marked with [REQUIRED].
# Optional vars have safe defaults or enable extra features.
# ============================================================

# ── Application ────────────────────────────────────────────
APP_NAME="Digital CMO AI"
APP_VERSION=0.2.0

# Set to false in production
DEBUG=false

HOST=0.0.0.0
PORT=8000

# ── Database [REQUIRED] ────────────────────────────────────
# PostgreSQL connection string.
# Railway auto-provides $DATABASE_URL when Postgres plugin is added.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://cmo_user:CHANGE_ME@db.host.example.com:5432/digital_cmo_prod

# ── Redis ─────────────────────────────────────────────────
# Redis connection string for caching, sessions, and job queues.
# Railway auto-provides $REDIS_URL when Redis plugin is added.
REDIS_URL=redis://:REDIS_PASSWORD@redis.host.example.com:6379/0

# ── Auth / JWT [REQUIRED] ──────────────────────────────────
# MUST be a long, random, unique string (min 32 chars).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email verification flow (set true for production)
REQUIRE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_EXPIRE_HOURS=48
PASSWORD_RESET_EXPIRE_MINUTES=60

# ── Public URLs [REQUIRED] ─────────────────────────────────
APP_BASE_URL=https://api.digital-cmo.ai
FRONTEND_BASE_URL=https://app.digital-cmo.ai

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS_CSV=https://app.digital-cmo.ai,https://digital-cmo.ai

# ── LLM — OpenAI [REQUIRED] ───────────────────────────────
# Primary LLM for all AI features.
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-CHANGE_ME
OPENAI_MODEL=gpt-4o

# ── LLM — Anthropic (optional) ────────────────────────────
# Used for Claude fallback / A/B routing.
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── LLM — Google (optional) ───────────────────────────────
# Used for Gemini / Google Search grounding.
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIza-CHANGE_ME

# ── Vector Store ──────────────────────────────────────────
VECTOR_DB_PATH=/app/data/vector_store
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIMENSION=1536

# ── Memory & Data Paths ────────────────────────────────────
MEMORY_BASE_PATH=/app/memory

# ── Stripe Billing (optional — enables paid plans) ────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
# Price IDs from Stripe dashboard
STRIPE_PRICE_PRO_MONTHLY=price_CHANGE_ME_PRO
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_CHANGE_ME_ENTERPRISE

# ── SMTP / Transactional Email ─────────────────────────────
# Supports: SendGrid, Mailgun, AWS SES, Postmark, or any SMTP.
# Leave blank to disable transactional email.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG.CHANGE_ME
SMTP_FROM_EMAIL=no-reply@digital-cmo.ai
SMTP_USE_TLS=true
SUPPORT_EMAIL=support@digital-cmo.ai
REPORTS_FROM_EMAIL=reports@digital-cmo.ai

# ── Monitoring & Observability ────────────────────────────

# Sentry — error tracking and performance monitoring
# Get from: https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME_PROJECT_ID

# PostHog — product analytics
# Get from: https://app.posthog.com/project/settings
POSTHOG_API_KEY=phc_CHANGE_ME
POSTHOG_HOST=https://app.posthog.com

# ── Token Accounting ──────────────────────────────────────
FREE_TIER_MONTHLY_TOKENS=10000
PRO_TIER_MONTHLY_TOKENS=100000
ENTERPRISE_TIER_MONTHLY_TOKENS=1000000

# ============================================================
# OPTIONAL CONNECTOR CREDENTIALS
# Leave blank → connector runs in demo/mock mode automatically.
# Fill in → connector uses the real third-party API.
# ============================================================

# ── Google Ads (OAuth2) ───────────────────────────────────
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

# ── Meta / Facebook Ads ───────────────────────────────────
META_ADS_ACCESS_TOKEN=
META_ADS_APP_ID=
META_ADS_APP_SECRET=

# ── TikTok Ads ────────────────────────────────────────────
TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_ADVERTISER_ID=

# ── LinkedIn ──────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Twitter / X ───────────────────────────────────────────
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# ── Facebook Pages ────────────────────────────────────────
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── SendGrid ──────────────────────────────────────────────
SENDGRID_API_KEY=

# ── Mailchimp ─────────────────────────────────────────────
MAILCHIMP_API_KEY=

# ── HubSpot CRM ───────────────────────────────────────────
HUBSPOT_API_KEY=
HUBSPOT_ACCESS_TOKEN=

# ── Salesforce ────────────────────────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_INSTANCE_URL=

# ── Zoho CRM ──────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# ── Google Analytics 4 ────────────────────────────────────
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_ANALYTICS_CREDENTIALS_JSON=

# ── Mixpanel ──────────────────────────────────────────────
MIXPANEL_API_SECRET=
MIXPANEL_PROJECT_ID=

# ── Shopify ───────────────────────────────────────────────
SHOPIFY_SHOP_NAME=
SHOPIFY_ACCESS_TOKEN=

# ── ActiveCampaign ────────────────────────────────────────
ACTIVECAMPAIGN_API_KEY=
ACTIVECAMPAIGN_ACCOUNT_URL=

# ── Klaviyo ───────────────────────────────────────────────
KLAVIYO_API_KEY=

# ── n8n Workflow Automation ───────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_DEFAULT_WEBHOOK_URL=
N8N_DEFAULT_WEBHOOK_PATH=

# ── SEMrush ───────────────────────────────────────────────
SEMRUSH_API_KEY=

# ── Slack ─────────────────────────────────────────────────
SLACK_BOT_TOKEN=

# ── Twilio ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── PostgreSQL (for docker-compose.prod.yml only) ─────────
# These are used by the postgres service in docker-compose.
# Not read directly by the backend (it uses DATABASE_URL instead).
POSTGRES_USER=cmo
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=digital_cmo
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
